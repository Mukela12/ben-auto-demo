generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  brand         String
  category      String
  tagline       String    @default("")
  description   String
  dailyRate     Int       // cents (rental price per day)
  depositAmount Int       // cents (rental deposit)
  seats         Int
  doors         Int       @default(4)
  transmission  String    @default("automatic")
  fuelType      String    @default("gasoline")
  horsepower    Int       @default(200)
  acceleration  String    @default("")
  luggage       String    @default("")
  imageUrl      String
  galleryUrls   String[]
  featured      Boolean   @default(false)
  available     Boolean   @default(true)

  // Buy/Rent listing mode
  listingType   String    @default("rent") // "rent" | "buy" | "both"
  salePrice     Int?      // cents (purchase price, e.g., 4500000 = $45,000)
  mileage       Int?      // miles
  year          Int?      // model year
  condition     String?   // "new" | "like_new" | "excellent" | "good"

  // Vehicle status (replaces simple available boolean for new logic)
  status        String    @default("available") // "available" | "rented" | "pending_sale" | "sold" | "maintenance" | "unlisted"

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  quoteRequests QuoteRequest[]
}

model Booking {
  id              String   @id @default(cuid())
  bookingRef      String   @unique
  status          String   @default("pending")
  pickupDate      DateTime
  returnDate      DateTime
  pickupLocation  String
  returnLocation  String
  totalPrice      Int      // cents
  depositAmount   Int      // cents
  stripePaymentId String?
  stripeDepositId String?
  depositStatus   String   @default("none")
  customerName    String
  customerEmail   String
  customerPhone   String?
  extras          Json?
  notes           String?
  canceledReason  String?
  carId           String
  car             Car      @relation(fields: [carId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuoteRequest {
  id                String    @id @default(cuid())
  referenceNumber   String    @unique
  status            String    @default("new") // "new" | "contacted" | "negotiating" | "quoted" | "sold" | "lost"

  // Car reference
  carId             String
  car               Car       @relation(fields: [carId], references: [id])

  // Customer info
  customerName      String
  customerEmail     String
  customerPhone     String
  message           String?

  // Optional details
  financingInterest Boolean   @default(false)
  tradeInInterest   Boolean   @default(false)

  // Admin tracking
  adminNotes        String?
  contactedAt       DateTime?
  closedAt          DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Location {
  id      String  @id @default(cuid())
  name    String
  address String
  city    String
  lat     Float?
  lng     Float?
  active  Boolean @default(true)
}
